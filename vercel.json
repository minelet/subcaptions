{
  "version": 2,
  "routes": [
    { "src": "/api/auth/google-callback", "dest": "/api/auth/google-callback.js" },
    { "src": "/api/auth/google",          "dest": "/api/auth/google.js" },
    { "src": "/api/admin/users",          "dest": "/api/admin/users.js" },
    { "src": "/api/admin/orders",         "dest": "/api/admin/orders.js" },
    { "src": "/api/admin/streak-events",  "dest": "/api/admin/streak-events.js" },
    { "src": "/api/admin/clip-finder-stats", "dest": "/api/admin/clip-finder-stats.js" },
    { "src": "/api/signup",               "dest": "/api/signup.js" },
    { "src": "/api/login",                "dest": "/api/login.js" },
    { "src": "/api/logout",               "dest": "/api/logout.js" },
    { "src": "/api/me",                   "dest": "/api/me.js" },
    { "src": "/api/use-credits",          "dest": "/api/use-credits.js" },
    { "src": "/api/shortify",             "dest": "/api/shortify.js" },
    { "src": "/api/capture-order",        "dest": "/api/capture-order.js" },
    { "src": "/admin.html",               "dest": "/admin.html" },
    { "src": "/editor.html",              "dest": "/editor.html" },
    { "handle": "filesystem" },
    { "src": "/(.*)",                     "dest": "/index.html" }
  ]
}
